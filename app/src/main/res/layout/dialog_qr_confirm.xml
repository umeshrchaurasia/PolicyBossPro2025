<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"

    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:backgroundTint="@color/bg_light"
    android:padding="24dp"

    android:background="@drawable/bg_bottom_sheet">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_sheet_handle"/>
    <TextView
        android:text="Confirm login"
        android:textStyle="bold"
        android:textSize="22sp"
        android:fontFamily="@font/poppinsbold"
        android:textColor="@color/black"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <com.google.android.material.divider.MaterialDivider
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="12dp"/>

    <TextView
        android:layout_marginTop="8dp"
        android:textSize="18sp"
        android:fontFamily="@font/poppinsmedium"
        android:text="You'll be logged into the desktop device after your verification"
        android:textColor="@color/colorText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- Location Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal">

        <TextView
            android:text="Location:"
            android:textStyle="bold"
            android:layout_width="0dp"
            android:layout_weight=".3"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tvLocation"

            android:layout_width="0dp"
            android:layout_weight=".7"
            android:layout_height="wrap_content"/>

    </LinearLayout>

    <!-- IP Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <TextView
            android:text="IP Address"
            android:textStyle="bold"
            android:layout_width="0dp"
            android:layout_weight=".3"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tvIp"
            android:layout_width="0dp"
            android:layout_weight=".7"
            android:layout_height="wrap_content"/>

    </LinearLayout>

    <!-- Device Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <TextView
            android:text="Device"
            android:textStyle="bold"
            android:layout_width="0dp"
            android:layout_weight=".3"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tvDevice"
            android:textSize="15sp"
            android:fontFamily="@font/poppinsbold"
            android:text=""
            android:textColor="@color/green"
            android:layout_width="0dp"
            android:layout_weight=".7"
            android:layout_height="wrap_content"/>

    </LinearLayout>

    <!-- Loader -->
    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/progressBar"
        android:visibility="invisible"
        android:indeterminate="true"
        android:layout_gravity="center"
        android:layout_marginTop="10dp"
        android:layout_width="36dp"
        android:layout_height="36dp"/>

    <LinearLayout
        android:layout_marginTop="10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            android:text="Cancel"
            android:backgroundTint="@color/red_custom"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirm"
            android:text="Confirm"
            android:backgroundTint="@color/button_color"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"/>

    </LinearLayout>

</LinearLayout>